{
  "name": "@tron-core/benchmarks",
  "type": "module",
  "private": true,
  "description": "Neutral, peer-review-grade benchmarks comparing LOON, TOON, JSON, YAML, XML, CSV across token efficiency, scaling, roundtrip fidelity and LLM retrieval accuracy.",
  "scripts": {
    "bench:all": "npm run bench:tokens && npm run bench:tokens:real && npm run bench:scaling && npm run bench:roundtrip && npm run bench:tokenizers && npm run bench:throughput && npm run bench:adversarial && npm run bench:gemini-1k",
    "bench:tokenizers": "node --import tsx/esm scripts/multi-tokenizer-benchmark.ts",
    "bench:tokens": "node --import tsx/esm scripts/token-efficiency-benchmark.ts",
    "bench:tokens:real": "node --import tsx/esm scripts/real-data-token-benchmark.ts",
    "bench:scaling": "node --import tsx/esm scripts/scaling-benchmark.ts",
    "bench:roundtrip": "node --import tsx/esm scripts/roundtrip-fidelity.ts",
    "bench:accuracy": "node --import tsx/esm --env-file=.env scripts/accuracy-benchmark.ts",
    "bench:accuracy:context": "node --import tsx/esm --env-file=.env scripts/accuracy-with-context-benchmark.ts",
    "bench:llm-task": "node --import tsx/esm --env-file=.env scripts/llm-real-task.ts",
    "bench:throughput": "node --import tsx/esm scripts/throughput-benchmark.ts",
    "bench:adversarial": "node --import tsx/esm scripts/adversarial-roundtrip.ts",
    "bench:gemini-1k": "node --import tsx/esm --env-file=.env scripts/gemini-1k-benchmark.ts",
    "export:loon": "node --import tsx/esm scripts/export-loon.ts",
    "fetch:github-repos": "node --import tsx/esm scripts/fetch-github-repos.ts"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/xai": "^3.0.67",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@clack/prompts": "^1.1.0",
    "@faker-js/faker": "^10.3.0",
    "@toon-format/toon": "^2.1.0",
    "ai": "^6.0.116",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.6.0",
    "fast-xml-parser": "^5.4.2",
    "gpt-tokenizer": "^3.4.0",
    "ofetch": "^1.5.1",
    "p-map": "^7.0.4",
    "p-queue": "^9.1.0",
    "tiktoken": "^1.0.22",
    "tsx": "^4.21.0",
    "unstorage": "^1.17.4",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@lenml/tokenizer-claude": "^3.7.2",
    "@lenml/tokenizer-gemini": "^3.7.2",
    "@lenml/tokenizer-gemma3": "^3.7.2",
    "@lenml/tokenizer-llama3_2": "^3.7.2",
    "@lenml/tokenizer-qwen3": "^3.7.2",
    "@lenml/tokenizers": "^3.7.2",
    "loon-core": "^1.0.1"
  }
}
